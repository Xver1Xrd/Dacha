# Syntax: docker/dockerfile:1.4
# Dacha backend - Go 1.25

# Stage 1: Builder
FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-w -s" -o dacha-backend

# Stage 2: Runtime
FROM alpine:latest
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/dacha-backend /usr/local/bin/dacha-backend
EXPOSE 8080
WORKDIR /app
ENTRYPOINT ["/usr/local/bin/dacha-backend"]